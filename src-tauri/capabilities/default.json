{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default",
    "fs:default",
    "fs:allow-read-all",
    "fs:allow-write-all",
    "fs:allow-mkdir-all",
    "notification:default"
  ]
}